# =============================================================================
# Kodemeio Mattermost - Production Environment Template
# =============================================================================
# Copy to .env.prod and fill in the values:
#   cp .env.example .env.prod
#
# Usage: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# =============================================================================

# =============================================================================
# DEPLOYMENT IDENTITY
# =============================================================================
DEPLOY_ENV=production
DEPLOY_NAME=mattermost-prod

# =============================================================================
# DOKPLOY PROJECT
# =============================================================================
DOKPLOY_PROJECT_NAME=kodemeio-mattermost
DOKPLOY_GITHUB_OWNER=tgunawandev
DOKPLOY_GITHUB_REPO=kodemeio-mattermost
DOKPLOY_GITHUB_BRANCH=main
DOKPLOY_COMPOSE_FILE=docker-compose.prod.yml
USE_ALL_ENV=true

# =============================================================================
# COMPOSE PROJECT
# =============================================================================
COMPOSE_PROJECT_NAME=mattermost
MM_DOMAIN=chat.kodeme.io

# =============================================================================
# MATTERMOST VERSION
# =============================================================================
MM_IMAGE_TAG=10.5

# =============================================================================
# POSTGRESQL (internal dedicated container)
# =============================================================================
# Generate: openssl rand -base64 32
MM_POSTGRESQL_USER=mmuser
MM_POSTGRESQL_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
MM_POSTGRESQL_NAME=mattermost

# =============================================================================
# AUTHENTIK SSO (OAuth2/OpenID Connect via GitLab provider)
# =============================================================================
# Configure in Authentik admin → Applications → Providers → OAuth2
AUTHENTIK_URL=https://auth.kodeme.io
AUTHENTIK_MATTERMOST_CLIENT_ID=CONFIGURE_IN_AUTHENTIK_ADMIN
AUTHENTIK_MATTERMOST_CLIENT_SECRET=CONFIGURE_IN_AUTHENTIK_ADMIN

# =============================================================================
# FILE STORAGE (S3 — Hetzner Object Storage)
# =============================================================================
MM_FILESETTINGS_DRIVERNAME=amazons3
MM_FILESETTINGS_MAXFILESIZE=256000000
MM_FILESETTINGS_AMAZONS3ACCESSKEYID=CONFIGURE_IN_HETZNER_CONSOLE
MM_FILESETTINGS_AMAZONS3SECRETACCESSKEY=CONFIGURE_IN_HETZNER_CONSOLE
MM_FILESETTINGS_AMAZONS3BUCKET=hz-kodemeio-mattermost-data
MM_FILESETTINGS_AMAZONS3ENDPOINT=nbg1.your-objectstorage.com
MM_FILESETTINGS_AMAZONS3REGION=nbg1
MM_FILESETTINGS_AMAZONS3SSL=true
MM_FILESETTINGS_AMAZONS3SIGNV2=false

# =============================================================================
# EMAIL (Mailcow)
# =============================================================================
MM_EMAILSETTINGS_SENDEMAILNOTIFICATIONS=true
MM_EMAILSETTINGS_ENABLESMTPAUTH=true
MM_EMAILSETTINGS_SMTPSERVER=mail.kodeme.io
MM_EMAILSETTINGS_SMTPPORT=587
MM_EMAILSETTINGS_SMTPUSERNAME=mattermost@kodeme.io
MM_EMAILSETTINGS_SMTPPASSWORD=CONFIGURE_IN_MAILCOW_ADMIN
MM_EMAILSETTINGS_CONNECTIONSECURITY=STARTTLS
MM_EMAILSETTINGS_FEEDBACKEMAIL=mattermost@kodeme.io
MM_EMAILSETTINGS_FEEDBACKNAME=Mattermost
MM_EMAILSETTINGS_REPLYTOADDRESS=mattermost@kodeme.io

# =============================================================================
# FEATURE SETTINGS
# =============================================================================
MM_PLUGINSETTINGS_ENABLEUPLOADS=true
MM_SERVICESETTINGS_ENABLEOPENSERVER=false
MM_TEAMSETTINGS_MAXUSERSPERTEAM=1000
MM_EMAILSETTINGS_ENABLEPREVIEWMODEBANNER=false
MM_EMAILSETTINGS_ENABLESIGNUPWITHEMAIL=false
MM_EMAILSETTINGS_ENABLESIGNINWITHEMAIL=true

# =============================================================================
# S3 BACKUP (Hetzner Object Storage)
# =============================================================================
S3_BACKUP_ENDPOINT=https://nbg1.your-objectstorage.com
S3_BACKUP_ACCESS_KEY=CONFIGURE_IN_HETZNER_CONSOLE
S3_BACKUP_SECRET_KEY=CONFIGURE_IN_HETZNER_CONSOLE
S3_BACKUP_BUCKET=hz-kodemeio-mattermost-backup
S3_BACKUP_REGION=nbg1

# =============================================================================
# BACKUP SCHEDULE
# =============================================================================
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4

# =============================================================================
# RESOURCE LIMITS
# =============================================================================
CPU_LIMIT_MM=2
MEMORY_LIMIT_MM=2G
CPU_LIMIT_DB=1
MEMORY_LIMIT_DB=1G
CPU_LIMIT_BACKUP=0.25
MEMORY_LIMIT_BACKUP=128M

# =============================================================================
# TENANT
# =============================================================================
TENANT=kodemeio

# =============================================================================
# TIMEZONE
# =============================================================================
TZ=Asia/Jakarta
